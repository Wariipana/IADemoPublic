# ── Groq ──────────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# ── Twilio ─────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886   # número sandbox de Twilio
TWILIO_WHATSAPP_TO=whatsapp:+51XXXXXXXXX     # tu número personal
TWILIO_CONTENT_SID=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxx  # SID del Content Template

# ── Gmail OAuth2 ───────────────────────────────────────────────────────────
GMAIL_CREDENTIALS_JSON=credentials.json      # descargado de Google Cloud Console
GMAIL_TOKEN_JSON=token.json                  # se genera automáticamente al autenticar
GMAIL_USER_ID=me

# ── Google Cloud Pub/Sub ───────────────────────────────────────────────────
GOOGLE_CLOUD_PROJECT=mi-proyecto-gcp
PUBSUB_TOPIC=gmail-notifications
PUBSUB_SUBSCRIPTION=gmail-notifications-sub

# ── Contenido de archivos sensibles (para Railway / producción) ────────────────
# Pega aquí el contenido completo de credentials.json (para no subir el archivo)
GMAIL_CREDENTIALS_CONTENT={"installed":{"client_id":"...","client_secret":"..."}}
# Pega aquí el contenido completo de token.json (generado por setup.py)
GMAIL_TOKEN_CONTENT={"token":"...","refresh_token":"..."}
